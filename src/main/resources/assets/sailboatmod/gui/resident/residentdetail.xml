    <view id="healthBar" size="140 11" pos="50 30"/>
    <text size="40 11" pos="8 30" color="gray" textalign="MIDDLE_RIGHT" label="HP"/>

    <view id="hungerBar" size="140 11" pos="50 44"/>
    <text size="40 11" pos="8 44" color="gray" textalign="MIDDLE_RIGHT" label="Food"/>

    <view id="happinessBar" size="140 11" pos="50 58"/>
    <text size="40 11" pos="8 58" color="gray" textalign="MIDDLE_RIGHT" label="Happy"/>

    <!-- Info section -->
    <text size="60 11" pos="16 78" color="gray" label="Gender:"/>
    <text id="gender" size="120 11" pos="80 78" color="black"/>

    <text size="60 11" pos="16 92" color="gray" label="Age:"/>
    <text id="age" size="120 11" pos="80 92" color="black"/>

    <text size="60 11" pos="16 106" color="gray" label="Culture:"/>
    <text id="culture" size="120 11" pos="80 106" color="black"/>

    <text size="60 11" pos="16 120" color="gray" label="Profession:"/>
