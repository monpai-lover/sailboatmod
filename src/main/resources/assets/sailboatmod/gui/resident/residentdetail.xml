    <text id="learning" size="40 11" pos="80 182" color="black"/>
    <text size="60 11" pos="120 182" color="gray" label="Martial:"/>
    <text id="martial" size="40 11" pos="180 182" color="black"/>
    <text size="60 11" pos="16 196" color="gray" label="Steward:"/>
    <text id="stewardship" size="40 11" pos="80 196" color="black"/>

    <!-- Action buttons -->
    <button id="assignJob" size="90 16" pos="16 218" label="Assign Job" textcolor="black"/>
    <button id="assignHome" size="90 16" pos="116 218" label="Assign Home" textcolor="black"/>

    <button id="familyTree" size="90 16" pos="16 240" label="Family Tree" textcolor="blue"/>
    <button id="dismiss" size="90 16" pos="116 240" label="Dismiss" textcolor="red"/>
